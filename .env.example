# ════════════════════════════════════════════════════════
# rigor.design — Frontend Environment Variables
# Copy to .env.local for local development
# NEVER commit .env.local to git
# ════════════════════════════════════════════════════════

# ── Firebase Client SDK (safe to expose in frontend) ────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Stripe Publishable Keys ──────────────────────────────
# Use TEST key during development, LIVE key in production
VITE_STRIPE_PUBLISHABLE_KEY_TEST=pk_test_
VITE_STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_

# Active key (set to TEST or LIVE value)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_

# ── Stripe Price IDs ─────────────────────────────────────
# Create these in your Stripe Dashboard > Products
VITE_STRIPE_PRO_PRICE_ID_TEST=price_test_
VITE_STRIPE_PRO_PRICE_ID_LIVE=price_live_
VITE_STRIPE_TEAM_PRICE_ID_TEST=price_test_
VITE_STRIPE_TEAM_PRICE_ID_LIVE=price_live_

# Active price IDs (set to TEST or LIVE values)
VITE_STRIPE_PRO_PRICE_ID=price_test_
VITE_STRIPE_TEAM_PRICE_ID=price_test_

# ── API Base URL ─────────────────────────────────────────
# Local: http://localhost:3001
# Production: https://api.rigor.design
VITE_API_URL=http://localhost:3001

# ── Feature Flags ────────────────────────────────────────
VITE_ENABLE_PAYMENTS=true
VITE_FREE_TIER_LIMIT=3
